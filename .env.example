APP_NAME="Russian Voice Clone TTS MVP"
ENVIRONMENT="development"
HOST="0.0.0.0"
PORT="8000"
DEBUG="true"

DATA_DIR="data"
SQLITE_PATH="data/sqlite/app.db"
UPLOADS_DIR="data/uploads"
OUTPUTS_DIR="data/outputs"
DATASETS_DIR="data/datasets"
TMP_DIR="data/tmp"
LOGS_DIR="data/logs"

FFMPEG_BIN="ffmpeg"

F5_TTS_MODEL_ID="Misha24-10/F5-TTS_RUSSIAN"
F5_TTS_COMMAND="python3 scripts/f5_tts_runner_real.py"
F5_TTS_TIMEOUT_SECONDS="180"

TRAINING_RUNNER_COMMAND=""
TRAINING_RUNNER_TIMEOUT_SECONDS="3600"

AUTO_ACCENT_ADAPTER="noop"

CELERY_BROKER_URL="redis://127.0.0.1:6379/0"
CELERY_RESULT_BACKEND="redis://127.0.0.1:6379/1"
